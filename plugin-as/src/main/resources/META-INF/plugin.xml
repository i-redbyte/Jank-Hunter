<idea-plugin>
  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationConfigurable
        instance="io.jankhunter.plugin.settings.JankHunterConfigurable"
        displayName="Jank Hunter"/>

    <configurationType implementation="io.jankhunter.plugin.run.JankHunterRunConfigurationType"/>

    <notificationGroup
        id="Jank Hunter"
        displayType="BALLOON"/>
  </extensions>

  <actions>
    <action
        id="JankHunter.ShowToolWindow"
        class="io.jankhunter.plugin.actions.OpenJankHunterToolWindowAction"
        text="Jank Hunter"
        description="Open Android jank analysis with Jank Hunter"
        icon="/icons/jankHunter.svg">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <keyboard-shortcut keymap="$default" first-keystroke="control alt J"/>
    </action>

    <action
        id="JankHunter.InspectClassEvidence"
        class="io.jankhunter.plugin.actions.InspectClassEvidenceAction"
        text="Inspect Jank Hunter Evidence For Class"
        description="Open Jank Hunter evidence for the current class">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
