<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Jank Hunter: утечки памяти</title>
  <style>{{baseCSS}}</style>
</head>
<body class="leak-page{{if .PresentationMode}} presentation-page{{end}}">
<header class="hero">
  <div class="report-hero-grid">
    <div class="report-hero-title">
      <div class="eyebrow">Jank Hunter · утечки памяти</div>
      <h1>Отчет по утечкам памяти</h1>
      <div class="subhead">создан {{.GeneratedAt}} · {{leakModeLabel .LeakReport.Mode}} · автономный HTML</div>
      <div class="hero-actions"><a class="math-link" href="#explorer">Открыть проводник утечек</a></div>
    </div>
    <div class="report-hero-lower">
      <div class="report-hero-context">
        <div class="env-card">
          <div class="env-title">{{.LeakReport.ModeTitle}}</div>
          <strong class="env-device">{{.LeakReport.Verdict}}</strong>
          <div class="env-subtitle">{{.LeakReport.ModeHint}}</div>
        </div>
      </div>
      <div class="report-hero-control">
        <div class="hero-meta">
          <div class="chip">Подозрения <strong>{{.LeakReport.Stats.TotalSuspects}}</strong></div>
          <div class="chip">Дамп <strong>{{.LeakReport.Stats.HeapConfirmed}}</strong></div>
          <div class="chip">Высокий риск <strong>{{.LeakReport.Stats.High}}</strong></div>
        </div>
      </div>
    </div>
  </div>
</header>
<nav class="nav">
  <a href="#summary">Сводка</a>
  <a href="#explorer">Граф</a>
  <a href="#registry">Реестр</a>
  <a href="#warnings">Ограничения</a>
</nav>
<main>
  <section id="summary" class="panel">
    <div class="panel-head">
      <div><h2>Краткий вердикт</h2><div class="panel-kicker">Легкий режим всегда доступен. Режим дампа кучи включается автоматически, когда CLI получил HPROF или JSON с доказательствами кучи.</div></div>
      <span class="pill">{{leakModeLabel .LeakReport.Mode}}</span>
    </div>
    <div class="grid">
      <div class="metric"><div class="label">Всего подозрений</div><div class="value">{{.LeakReport.Stats.TotalSuspects}}</div><div class="hint">удержаний {{.LeakReport.Stats.TotalRetained}}</div></div>
      <div class="metric"><div class="label">Критичные</div><div class="value">{{.LeakReport.Stats.High}}</div><div class="hint">предупреждений {{.LeakReport.Stats.Medium}}, норма {{.LeakReport.Stats.OK}}</div></div>
      <div class="metric"><div class="label">Подтверждены дампом</div><div class="value">{{.LeakReport.Stats.HeapConfirmed}}</div><div class="hint">только выполнение {{.LeakReport.Stats.RuntimeOnly}}</div></div>
      <div class="metric"><div class="label">Оценка удержания</div><div class="value">{{dataSize .LeakReport.Stats.EstimatedRetainedKB}}</div><div class="hint">макс. возраст {{humanDuration .LeakReport.Stats.MaxAgeMS}}</div></div>
      <div class="metric"><div class="label">Классы</div><div class="value">{{.LeakReport.Stats.UniqueClasses}}</div><div class="hint">держателей {{.LeakReport.Stats.UniqueHolders}}</div></div>
      <div class="metric"><div class="label">Без держателя</div><div class="value">{{.LeakReport.Stats.UnknownHolder}}</div><div class="hint">добавьте ownerHint для точности</div></div>
    </div>
    <p class="help-text">{{.LeakReport.ModeHint}}</p>
  </section>

  <details id="explorer" class="fold leak-report-fold" open>
    <summary><span>Проводник утечек</span><span class="fold-summary-meta">{{len .LeakReport.Items}} сценариев · граф ссылок</span></summary>
    <div class="fold-body">
      <p class="help-text">Выберите удержанный объект: справа появится цепочка удержания. В режиме дампа кучи это путь от корня GC; в легком режиме — вероятная цепочка выполнения.</p>
    {{if .LeakReport.Items}}
    <div class="leak-explorer" data-leak-explorer>
      <div class="leak-selector" aria-label="Список утечек">
        {{range .LeakReport.Items}}
        <button type="button" data-leak-select data-leak-target="leak-{{.Rank}}" data-leak-rank="{{.Rank}}" class="leak-select" role="tab" aria-controls="leak-{{.Rank}}">
          <span class="problem-score {{severityClass .Suspect.Severity}}">{{severityLabel .Suspect.Severity}}</span>
          <strong>{{.Suspect.ClassName}}</strong>
          <span>{{.Suspect.Holder}}</span>
          <small>{{.Suspect.Count}} шт · {{humanDuration .Suspect.MaxAgeMS}} · {{leakObjectKindLabel .Suspect.ObjectKind}}</small>
        </button>
        {{end}}
      </div>
      <div class="leak-graph-stage">
        {{range .LeakReport.Items}}
        <article id="leak-{{.Rank}}" class="leak-graph-panel" data-leak-panel>
          <div class="leak-panel-head">
            <div>
              <h3>{{.Suspect.ClassName}}</h3>
              <p>{{.Suspect.LeakChainSummary}}</p>
            </div>
            <span class="pill">{{if .Suspect.HeapEvidence}}доказательство из дампа{{else}}сигнал выполнения{{end}}</span>
          </div>
          {{leakGraphSVG .Graph}}
          <div class="leak-explain-grid">
            <div><strong>Что это значит</strong><p>{{.Suspect.Impact}}</p></div>
            <div><strong>Что проверить</strong><p>{{.Suspect.Recommendation}}</p></div>
            {{if .Suspect.LeakPattern}}<div><strong>Паттерн утечки</strong><p>{{.Suspect.LeakPattern}}{{if .Suspect.ReferenceMatchers}} · совпадения: {{range .Suspect.ReferenceMatchers}}<code>{{.}}</code> {{end}}{{end}}</p></div>{{end}}
          </div>
          <div class="leak-checklist-grid">
            <div><strong>План расследования</strong>{{range .Suspect.InvestigationSteps}}<span>{{.}}</span>{{end}}</div>
            <div><strong>Примеры фикса</strong>{{range .Suspect.FixExamples}}<span>{{.}}</span>{{end}}</div>
            <div><strong>Проверка после фикса</strong>{{range .Suspect.VerificationSteps}}<span>{{.}}</span>{{end}}</div>
          </div>
          {{if .Suspect.AlternativePathSummaries}}
          <div class="leak-alt-paths"><strong>Альтернативные цепочки</strong>{{range .Suspect.AlternativePathSummaries}}<span>{{.}}</span>{{end}}</div>
          {{end}}
          <div class="leak-chain-actions"><strong>Быстрые проверки цепочки</strong>{{range .Suspect.LeakChainActions}}<span>{{.}}</span>{{end}}</div>
        </article>
        {{end}}
      </div>
    </div>
    {{else}}
    <p class="help-text">Подозрений на утечки памяти нет. Если вы ожидаете увидеть Activity/Fragment, проверьте, что наблюдатель выполнения включен и сценарий дожил до задержки удержания.</p>
    {{end}}
    </div>
  </details>

  <details id="registry" class="fold leak-report-fold" open>
    <summary><span>Реестр утечек</span><span class="fold-summary-meta">{{len .LeakReport.Items}} строк · сортировка и фильтры</span></summary>
    <div class="fold-body">
    <p class="help-text">Таблица для сортировки и фильтрации: объект, держатель, контекст, размер, цепочка и доказательства.</p>
    {{scoreGuide "leak"}}
    <div class="code-registry" data-code-registry>
      <div class="registry-toolbar">
        <input type="search" data-code-registry-search placeholder="Фильтр по объекту, держателю, сценарию или рекомендации" aria-label="Фильтр утечек">
        <select data-code-registry-severity aria-label="Фильтр по риску">
          <option value="">Все уровни риска</option>
          <option value="high">Критично</option>
          <option value="medium">Предупреждение</option>
          <option value="ok">Норма</option>
        </select>
        <select data-code-registry-category aria-label="Фильтр по типу">
          <option value="">Все типы</option>
          {{range leakObjectKindOptions}}<option value="{{.Value}}">{{.Label}}</option>{{end}}
        </select>
        <span class="registry-counter" data-code-registry-count></span>
      </div>
      <div class="problem-empty">По текущим фильтрам утечек не найдено.</div>
      <table class="code-problem-table leak-table">
        <thead><tr><th><button type="button" data-code-sort="severity">Риск</button></th><th><button type="button" data-code-sort="class">Объект</button></th><th><button type="button" data-code-sort="category">Тип</button></th><th>Держатель</th><th>Контекст</th><th><button type="button" data-code-sort="score">Оценка</button></th><th>Удержанный размер</th><th>Цепочка</th><th>Что проверить</th><th>Доказательства</th></tr></thead>
        <tbody>
          {{range .LeakReport.Items}}
          <tr data-code-problem-row data-leak-row data-leak-target="leak-{{.Rank}}" data-score="{{printf "%.1f" .Suspect.Score}}" data-severity="{{.Suspect.Severity}}" data-class="{{.Suspect.ClassName}}" data-categories="{{.Suspect.ObjectKind}}" data-search="{{.PlainText}}">
            <td><span class="problem-score {{severityClass .Suspect.Severity}}">{{severityLabel .Suspect.Severity}}</span></td>
            <td><code>{{.Suspect.ClassName}}</code></td>
            <td>{{leakObjectKindLabel .Suspect.ObjectKind}}</td>
            <td><code>{{.Suspect.Holder}}</code><div class="muted">{{.Suspect.HolderQuality}}</div></td>
            <td>{{if .Suspect.Screen}}экран <code>{{.Suspect.Screen}}</code><br>{{end}}{{if .Suspect.Flow}}сценарий <code>{{.Suspect.Flow}}</code><br>{{end}}{{if .Suspect.Step}}шаг <code>{{.Suspect.Step}}</code>{{end}}</td>
            <td>{{printf "%.1f" .Suspect.Score}}<div class="muted">{{.Suspect.Count}} шт · {{humanDuration .Suspect.MaxAgeMS}}</div></td>
            <td>{{dataSize .Suspect.EstimatedRetainedKB}}<div class="muted">{{.Suspect.RetainedSizeConfidence}}</div></td>
            <td><div class="leak-dominator">{{range .Suspect.DominatorPath}}<span>{{.}}</span>{{end}}</div></td>
            <td>{{.Suspect.Recommendation}}</td>
            <td>{{.Suspect.Evidence}}{{if .Suspect.LeakPattern}}<div class="muted">паттерн: {{.Suspect.LeakPattern}}</div>{{end}}{{if .Suspect.GCRootCategory}}<div class="muted">категория корня: {{.Suspect.GCRootCategory}}</div>{{end}}</td>
          </tr>
          {{else}}<tr><td colspan="10" class="muted">Подозрений нет.</td></tr>{{end}}
        </tbody>
      </table>
    </div>
    </div>
  </details>

  <section id="warnings" class="panel">
    <div class="panel-head"><div><h2>Ограничения анализа</h2><div class="panel-kicker">Отчет явно показывает, где данные точные, а где это подсказка из выполнения.</div></div></div>
    {{range .LeakReport.Warnings}}<p class="warning">{{.}}</p>{{else}}<p class="help-text">Дополнительных предупреждений от анализа дампа и выполнения нет.</p>{{end}}
    <div class="leak-limitations">Легкий режим не читает поля объектов и не знает точный корень GC. Режим дампа кучи требует HPROF или доказательств кучи и может быть ограничен безопасными лимитами для больших дампов.</div>
  </section>
</main>
<script>{{reportJS}}</script>
</body>
</html>
